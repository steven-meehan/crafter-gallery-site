# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Claude Code tooling (memory, session state)
/.claude

# Client Specific Files
/src/assets
/src/index.css
/src/ConfigFiles/*.json
/content

# Client-specific CSS (per-client, not committed)
*.css
*.css.map

# Un-ignore CSS source files that belong in the repo
!src/**/*.module.css
!NewSiteSampleFiles/theme.css
!NewSiteSampleFiles/index.css